 *
 * Button order matches col-gpios in the DTS:
 * col 0 = right, col 1 = middle, col 2 = left.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
	keymap {
		compatible = "zmk,keymap";

		/*
		 * Stage 1: single layer.
		 * Binding order follows col-gpios (col 0 = right, col 1 =
		 * middle, col 2 = left):
		 *   right  = Paste      LC(V)
		 *   middle = Select-All LC(A)
		 *   left   = Copy       LC(C)
		 * The knob is a smooth vertical mouse wheel via the MA730
		 * driver's INPUT_REL_WHEEL events (see ma730_listener in the
		 * board DTS); no sensor-bindings here this stage.
		 */
		default_layer {
			bindings = <
				&kp LC(V)
				&kp LC(A)
				&kp LC(C)
			>;
		};
	};
};
