CONFIG_ARM_MPU=y
CONFIG_GPIO=y

CONFIG_MA730_INPUT=y
CONFIG_MA730_INPUT_TRIGGER_GLOBAL_THREAD=y

CONFIG_ZMK_POINTING=y

# Adafruit nRF52 UF2 bootloader.
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y

# Persistent ZMK settings.
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# WS2812 underglow.
# The LED strip is powered through the gpio1.11 ext-power rail. We keep the
# rail enabled and managed by src/rgb_indicator.c, and deliberately do NOT
# set CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER: coupling the rail to RGB on/off was
# the dead-underglow bug (ON_START never enabled the rail) and would also
# power-cycle the rail on every off-state flash. RGB on/off now only gates
# colour/animation; the rail stays powered.
CONFIG_ZMK_EXT_POWER=y
CONFIG_ZMK_RGB_UNDERGLOW=y
# Keep the toggled-on colour lit perpetually, including at idle. AUTO_OFF_IDLE
# would switch the LEDs off after the idle timeout and break "perpetually on".
CONFIG_ZMK_RGB_UNDERGLOW_AUTO_OFF_IDLE=n
# Must be explicit =n: ZMK's Kconfig.defaults forces this on by default, so
# merely omitting it leaves the rail coupled to RGB on/off (the bug).
CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER=n

CONFIG_ZMK_RGB_UNDERGLOW_ON_START=y
CONFIG_ZMK_RGB_UNDERGLOW_EFF_START=0
# Start white (layer 0 colour); the per-layer indicator takes over after boot.
CONFIG_ZMK_RGB_UNDERGLOW_HUE_START=0
CONFIG_ZMK_RGB_UNDERGLOW_SAT_START=0
CONFIG_ZMK_RGB_UNDERGLOW_BRT_START=80
