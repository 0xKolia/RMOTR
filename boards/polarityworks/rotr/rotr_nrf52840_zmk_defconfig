CONFIG_ARM_MPU=y
CONFIG_GPIO=y

CONFIG_MA730_INPUT=y
CONFIG_MA730_INPUT_TRIGGER_GLOBAL_THREAD=y

CONFIG_ZMK_POINTING=y

# Adafruit nRF52 UF2 bootloader.
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y

# Persistent ZMK settings.
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# WS2812 underglow.
CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_ZMK_RGB_UNDERGLOW_AUTO_OFF_IDLE=y
CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER=y
CONFIG_ZMK_EXT_POWER=y

# DIAGNOSTIC BUILD: USB logging + low-level direct-drive of the strip.
# Underglow stays compiled (so &rgb_ug in the keymap still builds) but is
# dormant at boot (ON_START=n, indicator off) so it does not fight the
# direct-drive thread, which owns the strip and logs device_is_ready() +
# led_strip_update_rgb() return codes over USB.
CONFIG_ZMK_USB_LOGGING=y
CONFIG_ROTR_RGB_DIAG=y
CONFIG_ROTR_RGB_INDICATOR=n
CONFIG_LED_STRIP_LOG_LEVEL_DBG=y
CONFIG_SPI_LOG_LEVEL_DBG=y

CONFIG_ZMK_RGB_UNDERGLOW_ON_START=n
CONFIG_ZMK_RGB_UNDERGLOW_EFF_START=0
CONFIG_ZMK_RGB_UNDERGLOW_HUE_START=0
CONFIG_ZMK_RGB_UNDERGLOW_SAT_START=0
CONFIG_ZMK_RGB_UNDERGLOW_BRT_START=80
