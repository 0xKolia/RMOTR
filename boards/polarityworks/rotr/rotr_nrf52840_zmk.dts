/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <common/nordic/nrf52840_uf2_boot_mode.dtsi>
#include <dt-bindings/led/led.h>
#include <dt-bindings/zmk/keys.h>
#include <input/processors.dtsi>
#include "rotr-pinctrl.dtsi"
#include "rotr-ma730.h"

/ {
	model = "ROTR";
	compatible = "polarityworks,rotr";

	chosen {
		zephyr,code-partition = &code_partition;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &cdc_acm_uart;
		zmk,kscan = &kscan0;
		zmk,underglow = &led_strip;
		zmk,battery = &vbatt;
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "col2row";
		debounce-press-ms = <5>;
		debounce-release-ms = <5>;

		row-gpios = <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
		/* col 0 = right, col 1 = middle, col 2 = left. */
		col-gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>,
		            <&gpio0 3 GPIO_ACTIVE_HIGH>,
		            <&gpio1 15 GPIO_ACTIVE_HIGH>;
	};

	ext-power {
		compatible = "zmk,ext-power-generic";
		control-gpios = <&gpio1 11 GPIO_ACTIVE_HIGH>;
	};

	vbatt: vbatt {
		compatible = "zmk,battery-voltage-divider";
		io-channels = <&adc 2>;
		/* 100 kOhm / 100 kOhm divider. */
		output-ohms = <100000>;
		full-ohms = <(100000 + 100000)>;
	};

	ma730_listener: ma730-listener {
		compatible = "zmk,input-listener";
		device = <&ma730>;
		/*
		 * Scroll smoothness knob. zip_scroll_scaler scales BOTH
		 * INPUT_REL_WHEEL and INPUT_REL_HWHEEL with track-remainders, so
		 * vertical and horizontal share one divisor. The driver emits
		 * ~1024 fine units/rev; <mult divisor> = <1 32> meters that to
		 * ~32 notches/rev (Stage 3 halved it from 16). Tune feel by
		 * changing the 32 (higher = slower). Selector resolution is
		 * separate (select-counts-per-step on the ma730 node).
		 */
		input-processors = <&zip_scroll_scaler 1 32>;
	};
};

&adc { status = "okay"; };
&gpiote { status = "okay"; };
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

zephyr_udc0: &usbd {
	status = "okay";
	cdc_acm_uart: cdc_acm_uart {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&spi1 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;

	ma730: ma730@0 {
		compatible = "polarityworks,ma730-input";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(8)>;
		reversal-threshold = <10>;
		/*
		 * Anti-ghosting: ignore tiny per-poll sensor jitter and clear
		 * stale partial movement after a short rest so drift cannot
		 * accumulate into a random key/scroll/selector tick.
		 */
		jitter-threshold = <4>;
		idle-reset-ms = <250>;

		/*
		 * Per-layer knob mode table (MA730_MODE_* from rotr-ma730.h),
		 * indexed by layer. Active layers 0-4, reserved 5-8, selector 9.
		 * To activate a reserved layer: set its mode + keycodes below and
		 * raise select-layer-count -- no C change needed.
		 */
		layer-modes = <
			MA730_MODE_INACTIVE	/* 0 default    */
			MA730_MODE_KEY		/* 1 brightness */
			MA730_MODE_KEY		/* 2 arrows     */
			MA730_MODE_SCROLL_H	/* 3 scroll-h   */
			MA730_MODE_SCROLL_V	/* 4 scroll-v   */
			MA730_MODE_KEY		/* 5 reserved: volume (pre-loaded) */
			MA730_MODE_INACTIVE	/* 6 reserved   */
			MA730_MODE_INACTIVE	/* 7 reserved   */
			MA730_MODE_INACTIVE	/* 8 reserved   */
			MA730_MODE_SELECT	/* 9 selector   */
		>;
		/* Clockwise keycode per KEY layer (0 = none). */
		layer-keycodes-cw = <
			0		/* 0 */
			F13		/* 1 brightness up   */
			RIGHT		/* 2 arrow right     */
			0		/* 3 */
			0		/* 4 */
			C_VOL_UP	/* 5 reserved volume */
			0		/* 6 */
			0		/* 7 */
			0		/* 8 */
			0		/* 9 */
		>;
		/* Counter-clockwise keycode per KEY layer (0 = none). */
		layer-keycodes-ccw = <
			0		/* 0 */
			F14		/* 1 brightness down */
			LEFT		/* 2 arrow left      */
			0		/* 3 */
			0		/* 4 */
			C_VOL_DN	/* 5 reserved volume */
			0		/* 6 */
			0		/* 7 */
			0		/* 8 */
			0		/* 9 */
		>;

		/* Selector cycles layers 0..(count-1); 5 => active 0-4 only. */
		select-layer-count = <5>;
		/* ~8 selector steps/rev, independent of scroll sensitivity. */
		select-counts-per-step = <8192>;

		/* Scroll layers: ~1024 fine units/rev (see binding). */
		scroll-counts-per-unit = <64>;
		/* Keyboard layers: ~24 detents/rev. */
		key-counts-per-detent = <2731>;
		/* Velocity acceleration: gain 6, capped at 4x. 0 gain = off. */
		scroll-accel-gain = <6>;
		scroll-accel-max = <1024>;
		/*
		 * Default directions: CW scrolls DOWN and pans RIGHT. Add
		 * invert-scroll / invert-hscroll here to flip if needed.
		 */
	};
};

&spi2 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		/*
		 * WS2812 timing at 4 MHz SPI clock:
		 *   one-frame  0x70 = 0b01110000 (~0.75 us high)
		 *   zero-frame 0x40 = 0b01000000 (~0.25 us high)
		 * Recalculate both values if the SPI clock frequency changes.
		 */
		spi-max-frequency = <4000000>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		chain-length = <3>;
		color-mapping = <LED_COLOR_ID_GREEN
		                 LED_COLOR_ID_RED
		                 LED_COLOR_ID_BLUE>;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/*
		 * Partition layout is fixed by the Adafruit nRF52 UF2
		 * bootloader. Do not modify these regions.
		 */
		sd_partition: partition@0 {
			reg = <0x00000000 0x00026000>;
		};
		code_partition: partition@26000 {
			reg = <0x00026000 0x000c6000>;
		};
		storage_partition: partition@ec000 {
			reg = <0x000ec000 0x00008000>;
		};
		boot_partition: partition@f4000 {
			reg = <0x000f4000 0x0000c000>;
		};
	};
};

&reg1 {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};
